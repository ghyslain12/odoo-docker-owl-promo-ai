<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!--
            Odoo 19 breaking change:
            - res.groups no longer has 'category_id' nor 'users' fields
            - categories are now 'res.groups.privilege' with a 'privilege_id' on res.groups
            - use 'comment' instead of description
        -->

        <record id="res_groups_privilege_promo_ai" model="res.groups.privilege">
            <field name="name">Promo AI</field>
            <field name="sequence">80</field>
        </record>

        <record id="group_promo_ai_user" model="res.groups">
            <field name="name">User</field>
            <field name="privilege_id" ref="res_groups_privilege_promo_ai"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Can read all Promo AI data and create/edit sales and tickets.</field>
        </record>

        <record id="group_promo_ai_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="privilege_id" ref="res_groups_privilege_promo_ai"/>
            <field name="implied_ids" eval="[(4, ref('group_promo_ai_user'))]"/>
            <field name="comment">Full access to all Promo AI data including materials and promotions.</field>
        </record>

    </data>
</odoo>
