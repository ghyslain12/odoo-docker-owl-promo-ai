<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="promo_ai_login_final" inherit_id="web.layout" name="Promo AI SPA Login">
        <xpath expr="//head" position="inside">
            <style t-if="request.httprequest.path == '/web/login'">
                body.o_login_page { background: #f5f5f5 !important; margin: 0 !important; padding: 0 !important; height: 100vh !important; overflow: hidden !important; display: block !important; }
                .o_login_page_card, .o_login_page footer, .oe_login_form, .o_database_list, .text-center { display: none !important; }

                .promo-navbar { background: #212121; color: #fff; height: 56px; display: flex; align-items: center; padding: 0 24px; font-weight: bold; position: fixed; top: 0; left: 0; width: 100%; z-index: 1000; }
                .promo-main { display: flex; position: fixed; top: 56px; left: 0; bottom: 0; right: 0; }

                .promo-sidebar { width: 240px; background: #3a3a3a; flex-shrink: 0; display: flex; flex-direction: column; height: 100%; }
                .promo-sidebar a { color: #bbbbbb; text-decoration: none; padding: 12px 20px; font-size: 0.9rem; border-left: 4px solid transparent; display: block; }
                .promo-sidebar a:hover, .promo-sidebar a.active { background: rgba(255,255,255,0.05); color: #fff; border-left-color: #4a5eb8; }
                .group-title { padding: 12px 20px 4px 20px; color: #ffffff; font-weight: 700; font-size: 0.85rem; }
                .sub-link { padding: 6px 20px 6px 40px !important; color: #999 !important; font-size: 0.8rem !important; }

                .promo-content-wrapper { flex-grow: 1; display: flex; flex-direction: column; background: #fff; }
                .promo-content { flex-grow: 1; display: flex; align-items: center; justify-content: center; }
                .promo-footer { height: 40px; display: flex; align-items: center; justify-content: center; font-size: 12px; color: #999; border-top: 1px solid #eee; }

                .promo-card { background: #fff; padding: 40px; width: 400px; border-radius: 4px; box-shadow: 0 4px 20px rgba(0,0,0,0.1); border: 1px solid #eee; }
                .promo-card h3 { margin-bottom: 25px; font-weight: bold; color: #333; }
                .promo-field { margin-bottom: 20px; text-align: left; }
                .promo-field label { display: block; font-size: 11px; color: #999; text-transform: uppercase; margin-bottom: 5px; font-weight: 600; }
                .promo-field input { width: 100%; border: none; border-bottom: 2px solid #ddd; background: #f9f9f9; padding: 10px; box-sizing: border-box; }

                /* Boutons jumeaux Angular */
                .promo-btn-group { display: flex; gap: 10px; margin-top: 25px; }
                .promo-btn { flex: 1; padding: 12px; border: none; border-radius: 4px; font-weight: 600; cursor: pointer; color: white !important; background: #4a5eb8; text-align: center; text-decoration: none; font-size: 0.85rem; }
                .promo-btn:hover { background: #3a4ea8; }
            </style>
        </xpath>

        <xpath expr="//body" position="inside">
            <t t-if="request.httprequest.path == '/web/login'">
                <div class="promo-navbar"></div>
                <div class="promo-main">
                    <nav class="promo-sidebar">
                        <a href="#" class="active">Home</a>
                        <div class="group-title">Provisioning</div>
                        <a href="#" class="sub-link">sale</a>
                        <div class="group-title">Ticketing</div>
                        <a href="#" class="sub-link">ticket</a>
                        <div class="group-title">Users</div>
                        <a href="#" class="sub-link">client</a>
                        <div class="group-title">Materials</div>
                        <a href="#" class="sub-link">material</a>
                    </nav>
                    <div class="promo-content-wrapper">
                        <div class="promo-content">
                            <div class="promo-card">
                                <h3>Promo AI</h3>
                                <form action="/web/login" method="post">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    <div class="promo-field">
                                        <label>User</label>
                                        <input type="text" name="login" t-att-value="login" required="required" autofocus="autofocus"/>
                                    </div>
                                    <div class="promo-field">
                                        <label>Password</label>
                                        <input type="password" name="password" required="required" autocomplete="current-password"/>
                                    </div>
                                    <input type="hidden" name="redirect" t-att-value="redirect"/>

                                    <div class="promo-btn-group">
                                        <button type="submit" class="promo-btn">Login</button>
                                        <a href="/web/signup" class="promo-btn">Register</a>
                                    </div>
                                </form>
                            </div>
                        </div>
                        <div class="promo-footer">© 2025 - footer</div>
                    </div>
                </div>
            </t>
        </xpath>
    </template>
</odoo>
