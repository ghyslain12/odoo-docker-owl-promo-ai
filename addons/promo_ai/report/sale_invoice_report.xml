<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_sale_invoice_report" model="ir.actions.report">
        <field name="name">Sale Invoice</field>
        <field name="model">promo_ai.sale</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">promo_ai.report_sale_invoice_template</field>
        <field name="report_file">promo_ai.report_sale_invoice_template</field>
        <field name="print_report_name">
            (object.name or 'INV') + '-' + (object.invoice_country or 'fr').upper()
        </field>
        <field name="binding_model_id" ref="model_promo_ai_sale"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="base.paperformat_euro"/>
    </record>

</odoo>
