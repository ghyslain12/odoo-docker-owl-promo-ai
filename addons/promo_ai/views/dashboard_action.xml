<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- 1. L'action qui charge ton Dashboard personnalisé (Owl) -->
    <record id="action_promo_ai_dashboard" model="ir.actions.client">
        <field name="name">Dashboard</field>
        <field name="tag">promo_ai.dashboard_tag</field>
        <field name="target">main</field>
    </record>

    <!-- 2. FORCE ODOO A OUVRIR CE DASHBOARD APRES LE LOGIN -->
    <record id="base.group_user" model="res.groups">
        <field name="home_action_id" ref="action_promo_ai_dashboard"/>
    </record>

</odoo>
