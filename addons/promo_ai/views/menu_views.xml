              web_icon="promo_ai,static/description/icon.png"/>

    <!-- Home (Pointe vers l'action_client corrigée au dessus) -->
    <menuitem id="menu_promo_ai_dashboard"
              name="Home"
              parent="menu_promo_ai_root"
              action="action_promo_ai_dashboard"
              sequence="10"/>

    <!-- Provisioning -->
    <menuitem id="menu_group_provisioning" name="Provisioning" parent="menu_promo_ai_root" sequence="20"/>
