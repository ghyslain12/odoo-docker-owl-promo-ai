    <menuitem id="menu_group_materials" name="Materials" parent="menu_promo_ai_root" sequence="50"/>
    <menuitem id="menu_promo_ai_material" name="Material" parent="menu_group_materials" action="action_promo_ai_material" sequence="10"/>

    <!-- Promotions -->
    <menuitem id="menu_promo_ai_promotion"
              name="Promotions"
              parent="menu_promo_ai_root"
