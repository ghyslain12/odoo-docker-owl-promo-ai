<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Dashboard kanban-style for Sales -->
    <record id="view_promo_ai_sale_kanban" model="ir.ui.view">
        <field name="name">promo_ai.sale.kanban</field>
        <field name="model">promo_ai.sale</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" sample="1">
                <field name="name"/>
                <field name="titre"/>
                <field name="customer_id"/>
                <field name="total_amount"/>
                <field name="currency_id"/>
                <field name="ticket_count"/>
                <field name="invoice_generated"/>
                <templates>
                    <t t-name="card">
                        <div class="o_kanban_record_top">
                            <div class="o_kanban_record_headings">
                                <strong class="o_kanban_record_title">
                                    <field name="titre"/>
                                </strong>
                                <span class="o_kanban_record_subtitle">
                                    <field name="name"/>
                                </span>
                            </div>
                            <div t-if="record.invoice_generated.raw_value"
                                 class="badge text-bg-success">Invoice</div>
                        </div>
                        <div class="o_kanban_record_body">
                            <field name="customer_id"/> —
                            <field name="total_amount" widget="monetary"
                                   options="{'currency_field': 'currency_id'}"/>
                        </div>
                        <div class="o_kanban_record_bottom">
                            <div class="oe_kanban_bottom_left">
                                <span class="badge text-bg-info">
                                    <t t-esc="record.ticket_count.value"/> tickets
                                </span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Action for kanban view -->
    <record id="action_promo_ai_sale_kanban" model="ir.actions.act_window">
        <field name="name">Sales Dashboard</field>
        <field name="res_model">promo_ai.sale</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No sales yet!</p>
        </field>
    </record>

</odoo>
