<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─── List view ─── -->
    <record id="view_promo_ai_material_list" model="ir.ui.view">
        <field name="name">promo_ai.material.list</field>
        <field name="model">promo_ai.material</field>
        <field name="arch" type="xml">
            <list string="Materials" decoration-muted="not active">
                <field name="designation"/>
                <field name="price" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="active_promotion_id" optional="show"/>
                <field name="sale_count" string="Sales" widget="badge"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- ─── Form view ─── -->
    <record id="view_promo_ai_material_form" model="ir.ui.view">
        <field name="name">promo_ai.material.form</field>
        <field name="model">promo_ai.material</field>
        <field name="arch" type="xml">
            <form string="Material">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_sales"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-shopping-cart">
                            <field name="sale_count" widget="statinfo" string="Sales"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger"
                            invisible="active"/>
                    <group>
                        <group string="General Information">
                            <field name="designation"/>
                            <field name="price" widget="monetary"
                                   options="{'currency_field': 'currency_id'}"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="active"/>
                        </group>
                        <group string="Active Promotion">
                            <field name="active_promotion_id" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Promotions" name="promotions">
                            <field name="promotion_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="promo_type"/>
                                    <field name="discount_label"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'active'"
                                           decoration-warning="state == 'scheduled'"
                                           decoration-danger="state == 'expired'"
                                           decoration-muted="state == 'disabled'"/>
                                    <field name="priority"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ─── Search view ─── -->
    <record id="view_promo_ai_material_search" model="ir.ui.view">
        <field name="name">promo_ai.material.search</field>
        <field name="model">promo_ai.material</field>
        <field name="arch" type="xml">
            <search string="Search Materials">
                <field name="designation" filter_domain="[('designation','ilike',self)]"/>
                <filter string="Active" name="active" domain="[('active','=',True)]"/>
                <filter string="Archived" name="archived" domain="[('active','=',False)]"/>
                <separator/>
                <filter string="Has Active Promotion" name="has_promo"
                        domain="[('has_active_promotion','=',True)]"/>
                <group>
                    <filter string="Designation" name="group_designation"
                            context="{'group_by': 'designation'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ─── Action ─── -->
    <record id="action_promo_ai_material" model="ir.actions.act_window">
        <field name="name">Materials</field>
        <field name="res_model">promo_ai.material</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_promo_ai_material_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first material!
            </p>
            <p>Materials are products that can be added to sales with promotional discounts.</p>
        </field>
    </record>

</odoo>
