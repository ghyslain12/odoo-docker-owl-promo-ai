<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="promo_ai.Dashboard" owl="1">
        <div class="o_promo_dashboard_wrapper">
            <div class="promo-main-content">
                <header class="promo-header">
                    <h2 class="mb-0 fw-bold">Dashboard Overview</h2>
                    <div class="user-info">Admin</div>
                </header>

                <div class="p-4">
                    <t t-if="state.loading">
                        <div class="text-center p-5"><div class="spinner-border text-primary"/></div>
                    </t>
                    <t t-else="">
                        <div class="row g-3 mb-4">
                            <div class="col-md-3">
                                <div class="promo-card-kpi" t-on-click="openSales">
                                    <div class="kpi-icon bg-primary"><i class="fa fa-shopping-cart"/></div>
                                    <div class="ms-3">
                                        <div class="text-muted small fw-bold">TOTAL SALES</div>
                                        <div class="fs-4 fw-bold" t-esc="state.sales_total"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="card border-0 shadow-sm overflow-hidden" style="border-radius: 8px;">
                            <div class="card-header bg-white py-3 border-0">
                                <h6 class="mb-0 fw-bold">Recent Sales</h6>
                            </div>
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th class="ps-4">Ref</th>
                                            <th>Title</th>
                                            <th class="text-end pe-4">Total</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="state.recent_sales" t-as="sale" t-key="sale.id">
                                            <tr t-on-click="() => this.openSale(sale.id)" class="cursor-pointer">
                                                <td class="ps-4"><span class="badge bg-light text-dark border"><t t-esc="sale.name"/></span></td>
                                                <td class="fw-medium text-muted"><t t-esc="sale.titre"/></td>
                                                <td class="text-end pe-4 fw-bold text-dark"><t t-esc="formatCurrency(sale.total_amount)"/></td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </t>
                </div>
            </div>
        </div>
    </t>
</templates>
